@inject AppRoutesService AppRoutesService

<div class="header-shell">
    <div class="header-top">
        <div class="header-brand-row">
            <a class="navbar-brand app-brand" href="@AppRoutesService.GetPath(AppPage.Home)">
                <span class="brand-mark">
                    <img src="favicon.png" alt="PassManager" class="brand-mark-image" />
                </span>
                <span class="brand-copy">
                    <strong>PassManager</strong>
                    <small>Gestion de contrasenas</small>
                </span>
            </a>

            <button class="menu-toggle"
                    type="button"
                    title="Mostrar u ocultar menu"
                    aria-label="Mostrar u ocultar menu"
                    aria-expanded="@isMenuExpanded"
                    @onclick="ToggleMenu">
                <span class="menu-toggle-bar"></span>
                <span class="menu-toggle-bar"></span>
                <span class="menu-toggle-bar"></span>
            </button>
        </div>

        <div class="header-side">
            <div class="header-copy">
                <span class="header-kicker">PassManager</span>
                <p class="header-summary">
                    Genera claves y pines numericos a partir de una clave privada y una clave publica.
                </p>
            </div>

            <div class="header-actions">
                <a class="header-link header-link-accent"
                   href="https://solarosquiere.github.io/CV/Inicio"
                   target="_blank"
                   rel="noopener noreferrer">
                    <RadzenIcon Icon="person" />
                    Autor
                </a>
            </div>
        </div>
    </div>

    <nav class="header-nav @(isMenuExpanded ? "menu-expanded" : "menu-collapsed")" aria-label="Navegacion principal">
        <NavLink class="header-link header-link-accent header-nav-link"
                 href="@AppRoutesService.GetGeneratorUri(GeneratorKind.Password)"
                 Match="NavLinkMatch.Prefix">
            <span class="nav-title">Generador de clave</span>
            <small class="nav-subtitle">Clave consistente</small>
        </NavLink>
        <NavLink class="header-link header-link-accent header-nav-link"
                 href="@AppRoutesService.GetGeneratorUri(GeneratorKind.NumericCode)"
                 Match="NavLinkMatch.Prefix">
            <span class="nav-title">Codigo numerico</span>
            <small class="nav-subtitle">PIN de 4 a 16 cifras</small>
        </NavLink>
        <NavLink class="header-link header-link-accent header-nav-link"
                 href="@AppRoutesService.GetPath(AppPage.Documentation)">
            <span class="nav-title">Documentacion</span>
            <small class="nav-subtitle">Guia rapida de uso</small>
        </NavLink>
    </nav>
</div>

@code {
    private bool isMenuExpanded = true;

    private void ToggleMenu()
    {
        isMenuExpanded = !isMenuExpanded;
    }
}
