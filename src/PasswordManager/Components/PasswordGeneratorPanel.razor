@inject DeterministicSecretService SecretService
@inject IJSRuntime JSRuntime
@inject TextVisibilityService TextVisibilityService
@implements IDisposable

<EditForm EditContext="@editContext">
    <DataAnnotationsValidator />

    <RadzenStack Gap="1rem">
        <div class="hero-block">
            <RadzenText TextStyle="TextStyle.DisplayH4" TagName="TagName.H2">Generador de clave de Texto</RadzenText>
            <RadzenText TextStyle="TextStyle.Body1" class="muted-text hero-copy">
                Generar una contraseña general,con al menos: mayuscula,minuscula,numericos y simbolo, desde 15 hasta 128 letras.
            </RadzenText>
            <div class="feature-strip">
                <span class="feature-pill">Generar claves de texto </span>
                <span class="feature-pill">Longitud variable</span>
                <span class="feature-pill">Misma entrada, misma clave de texto</span>
                <span class="feature-pill">De 15 a 128 digitos</span>
            </div>
        </div>

        <div class="field-group">
            <div class="field-label-row">
                <label class="field-label" for="privateKey">Clave privada</label>
                <span class="field-help" tabindex="0">
                    ?
                    <span class="field-tooltip">Tu clave privada debe ser tu contrasena personal e intransferible. No deberias compartirla con nadie.</span>
                </span>
            </div>
            <RadzenTextBox @bind-Value="request.PrivateKey"
                           Name="privateKey"
                           Placeholder="Clave privada"
                           Type="@TextInputType"
                           Style="width: 100%;"
                           class="modern-input" />
            <div class="field-hint">Se usa como tu secreto personal. Debe ser solo tuyo.</div>
            <ValidationMessage For="@(() => request.PrivateKey)" />
        </div>

        <div class="field-group">
            <div class="field-label-row">
                <label class="field-label" for="publicKey">Clave publica</label>
                <span class="field-help" tabindex="0">
                    ?
                    <span class="field-tooltip">Las claves publicas son los sitios o servicios a los que quieres acceder, por ejemplo una web, app o plataforma.</span>
                </span>
            </div>
            <RadzenTextBox @bind-Value="request.PublicKey"
                           Name="publicKey"
                           Placeholder="Clave publica"
                           Type="@TextInputType"
                           Style="width: 100%;"
                           class="modern-input" />
            <div class="field-hint">Usa aqui el nombre del sitio, app o servicio al que quieres entrar.</div>
            <ValidationMessage For="@(() => request.PublicKey)" />
        </div>

        <div class="field-group">
            <label class="field-label" for="passwordLength">Longitud deseada</label>
            <RadzenNumeric @bind-Value="request.Length"
                           Name="passwordLength"
                           TValue="int?"
                           Min="15"
                           Max="128"
                           Step="1"
                           Style="width: 100%;"
                           class="@NumericInputClass" />
            <div class="field-hint">Obligatoria. Debe estar entre 15 y 128 caracteres.</div>
            <ValidationMessage For="@(() => request.Length)" />
        </div>

        <RadzenButton Text="Generar"
                      Icon="key"
                      ButtonStyle="ButtonStyle.Primary"
                      Click="@GeneratePassword"
                      Style="width: 100%;"
                      class="primary-action" />

        <div class="result-panel">
            <label class="field-label">Resultado</label>
            <div class="result-actions">
                <RadzenTextBox Value="@generatedPassword"
                               ReadOnly="true"
                               Type="@TextInputType"
                               Style="width: 100%;"
                               class="modern-input result-box" />
                <RadzenButton Text="Copiar"
                              Icon="content_copy"
                              Variant="Variant.Flat"
                              Click="@CopyPassword"
                              Disabled="@string.IsNullOrWhiteSpace(generatedPassword)"
                              class="copy-action" />
            </div>
        </div>
    </RadzenStack>
</EditForm>

@code {
    private readonly PasswordGenerationRequest request = new();
    private EditContext editContext = default!;
    private string generatedPassword = string.Empty;
    private string TextInputType => TextVisibilityService.IsVisible ? "text" : "password";
    private string NumericInputClass => TextVisibilityService.IsVisible ? "modern-input" : "modern-input masked-numeric-input";

    protected override void OnInitialized()
    {
        editContext = new EditContext(request);
        TextVisibilityService.Changed += HandleVisibilityChanged;
    }

    public void Dispose()
    {
        TextVisibilityService.Changed -= HandleVisibilityChanged;
    }

    private void HandleVisibilityChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private void GeneratePassword()
    {
        if (!editContext.Validate())
        {
            generatedPassword = string.Empty;
            return;
        }

        generatedPassword = SecretService.GeneratePassword(request.PrivateKey, request.PublicKey, request.Length!.Value);
    }

    private async Task CopyPassword()
    {
        if (string.IsNullOrWhiteSpace(generatedPassword))
        {
            return;
        }

        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", generatedPassword);
    }
}

